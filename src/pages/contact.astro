---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPageContent } from "../data/content";
import { getDefaultPageSeo } from "../data/seo";
import { siteConfig } from "../data/site";

const slug = "contact-prise-de-rendez-vous";
const page = await getPageContent(slug);
const defaultSeo = getDefaultPageSeo("/contact");
const title = page.seoTitle?.trim() || defaultSeo.title;
const description = page.seoDescription?.trim() || defaultSeo.description;
const html = page.html
  .replace(/<div class="wpcf7[\s\S]*?<div class="wpcf7-response-output"[^>]*><\/div>\s*<\/form>\s*<\/div>/gi, "")
  .replace(
    /<p>\s*Nous pouvons nous rencontrer[\s\S]*?<\/p>\s*<p>\s*Afin de prendre rendez-vous,[\s\S]*?<\/p>\s*<p>\s*<a class="btn-liberlo"[\s\S]*?<\/p>\s*<p>\s*Pour me contacter depuis ce site,[\s\S]*?<\/p>/gi,
    "",
  )
  .replace(/<p[^>]*>[\s\S]*?Nous pouvons nous rencontrer[\s\S]*?<\/p>/gi, "")
  .replace(/<p[^>]*>[\s\S]*?Afin de prendre rendez-vous[\s\S]*?<\/p>/gi, "")
  .replace(/<p[^>]*>[\s\S]*?RDV sur Liberlo\.com[\s\S]*?<\/p>/gi, "")
  .replace(/<p[^>]*>[\s\S]*?Pour me contacter depuis ce site[\s\S]*?<\/p>/gi, "")
  .replace(/<p[^>]*>[\s\S]*?Votre nom[\s\S]*?<\/p>/gi, "")
  .replace(/<p[^>]*>[\s\S]*?Votre mail[\s\S]*?<\/p>/gi, "")
  .replace(/<p[^>]*>[\s\S]*?Votre message[\s\S]*?<\/p>/gi, "")
  .replace(/<p[^>]*>\s*Nous pouvons nous rencontrer à mon cabinet, à votre domicile ou par visio \(Zoom par exemple\)\.\s*<\/p>/gi, "")
  .replace(/<p[^>]*>\s*Afin de prendre rendez-vous, merci de cliquer sur le bouton ci-dessous\s*:?\s*<\/p>/gi, "")
  .replace(/<p[^>]*>[\s\S]*?RDV sur Liberlo\.com[\s\S]*?<\/p>/gi, "")
  .replace(/<p[^>]*>\s*Pour me contacter depuis ce site, merci de remplir le formulaire ci-dessous\s*<\/p>/gi, "")
  .replace(/<p>\s*Votre nom\s*<br\s*\/?>\s*<\/p>/gi, "")
  .replace(/<p>\s*Votre mail\s*<br\s*\/?>\s*<\/p>/gi, "")
  .replace(/<p>\s*Sujet\s*<br\s*\/?>\s*<\/p>/gi, "")
  .replace(/<p>\s*Votre message\s*<br\s*\/?>\s*<\/p>/gi, "")
  .replace(/<p>\s*Audrey\s*<\/p>/gi, "");
const contactFormEndpoint =
  import.meta.env.PUBLIC_CONTACT_FORM_ENDPOINT?.trim() ||
  import.meta.env.PUBLIC_FIREBASE_CONTACT_ENDPOINT?.trim() ||
  "/contact.php";
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY?.trim() || "";
const hasConfig = Boolean(contactFormEndpoint && turnstileSiteKey);

const structuredData = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: page.title,
  description,
  url: "https://naturaufeminin.fr/contact",
  inLanguage: "fr-FR",
};
---

<BaseLayout
  title={title}
  description={description}
  keywords={defaultSeo.keywords}
  structuredData={structuredData}
>
  <article class="section wp-content" aria-labelledby="page-title">
    <h1 id="page-title">{page.title}</h1>
    <div class="contact-intro" set:html={html}></div>
    <section class="contact-choices" aria-labelledby="contact-choices-title">
      <h2 id="contact-choices-title">Comment souhaitez-vous être accompagnée ?</h2>
      <p class="contact-choices-intro">
        Vous pouvez réserver en <strong>cabinet</strong>, à <strong>domicile</strong> ou en <strong>visio</strong>.
      </p>
      <ul class="contact-choices-list">
        <li><strong>Cabinet</strong> : à Fleurieux-sur-l'Arbresle.</li>
        <li><strong>Domicile</strong> : selon votre secteur.</li>
        <li><strong>Visio</strong> : Zoom ou autre solution simple.</li>
      </ul>
      <a class="btn btn-primary contact-booking-btn" href={siteConfig.bookingUrl} target="_blank" rel="noopener noreferrer">
        Prendre rendez-vous sur Liberlo
      </a>
      <p class="contact-choices-help">
        Pour une question rapide, utilisez aussi le formulaire juste en dessous.
      </p>
    </section>

    <section class="contact-form-section">
      <p class="contact-form-intro">
        Réponse sous 48h ouvrées. Vos données sont utilisées uniquement pour vous recontacter.
      </p>

      <div id="form-status-slot"></div>
      {!hasConfig && (
        <p id="form-status-message" class="form-alert form-alert-error" role="alert">
          Le formulaire n'est pas encore configuré. Merci de me contacter par téléphone.
        </p>
      )}

      <form
        id="contact-form"
        class="contact-form"
        method="post"
        action={contactFormEndpoint || "#"}
        novalidate
        data-endpoint={contactFormEndpoint}
      >
        <input type="hidden" name="originPath" value="/contact" />
        <input type="hidden" id="formStartedAt" name="formStartedAt" value="" />
        <div class="hp-wrapper" aria-hidden="true">
          <label for="website">Site web</label>
          <input
            id="website"
            name="website"
            type="text"
            tabindex="-1"
            autocomplete="off"
            inputmode="url"
          />
        </div>

        <div class="form-grid">
          <div class="form-field">
            <label for="firstName">Prénom <span aria-hidden="true">*</span></label>
            <input id="firstName" name="firstName" type="text" autocomplete="given-name" required maxlength="80" />
          </div>
          <div class="form-field">
            <label for="lastName">Nom <span aria-hidden="true">*</span></label>
            <input id="lastName" name="lastName" type="text" autocomplete="family-name" required maxlength="80" />
          </div>
          <div class="form-field">
            <label for="email">Email <span aria-hidden="true">*</span></label>
            <input id="email" name="email" type="email" autocomplete="email" required maxlength="254" />
          </div>
          <div class="form-field">
            <label for="phone">Téléphone</label>
            <input id="phone" name="phone" type="tel" autocomplete="tel" inputmode="tel" maxlength="30" />
          </div>
        </div>

        <div class="form-field">
          <label for="subject">Sujet <span aria-hidden="true">*</span></label>
          <input id="subject" name="subject" type="text" required maxlength="120" />
        </div>

        <div class="form-field">
          <label for="message">Message <span aria-hidden="true">*</span></label>
          <textarea
            id="message"
            name="message"
            rows="7"
            required
            minlength="10"
            maxlength="5000"
          ></textarea>
        </div>

        <div class="form-check">
          <input id="consent" name="consent" type="checkbox" value="yes" required />
          <label for="consent">
            J'accepte que mes données soient traitées pour être recontactée, selon la
            <a href="/politique-de-confidentialite">politique de confidentialité</a>.
          </label>
        </div>

        <div class="form-turnstile">
          <div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-theme="auto"></div>
        </div>

        <p class="form-help">
          Les champs marqués d'un <span aria-hidden="true">*</span> sont obligatoires.
        </p>

        <button class="btn btn-primary form-submit" type="submit" disabled={!hasConfig}>
          Envoyer ma demande
        </button>

        <p class="form-live" id="form-live" role="status" aria-live="polite"></p>
      </form>
    </section>
  </article>

  <Fragment slot="head">
    <script
      src="https://challenges.cloudflare.com/turnstile/v0/api.js"
      async
      defer
      referrerpolicy="no-referrer"
    ></script>
    <script is:inline>
      window.addEventListener("DOMContentLoaded", () => {
        const form = document.querySelector("#contact-form");
        if (!(form instanceof HTMLFormElement)) return;

        const endpoint = form.dataset.endpoint || "";
        const startedAtInput = document.querySelector("#formStartedAt");
        const liveRegion = document.querySelector("#form-live");
        const submitButton = form.querySelector("button[type='submit']");
        const statusSlot = document.querySelector("#form-status-slot");

        const setLiveText = (message) => {
          if (liveRegion instanceof HTMLElement) {
            liveRegion.textContent = message;
          }
        };

        const renderStatusMessage = (kind, text) => {
          if (!(statusSlot instanceof HTMLElement)) return;
          statusSlot.innerHTML = "";
          const p = document.createElement("p");
          p.id = "form-status-message";
          p.className = `form-alert form-alert-prominent ${kind === "success" ? "form-alert-success" : "form-alert-error"}`;
          p.setAttribute("role", kind === "success" ? "status" : "alert");
          const icon = kind === "success" ? "✅" : "⚠️";
          p.textContent = `${icon} ${text}`;
          statusSlot.appendChild(p);
        };

        const clearStatusMessage = () => {
          const currentStatus = document.querySelector("#form-status-message");
          if (currentStatus instanceof HTMLElement && currentStatus.parentElement === statusSlot) {
            currentStatus.remove();
          }
        };

        const queryStatus = new URLSearchParams(window.location.search).get("status");
        if (queryStatus === "success") {
          renderStatusMessage("success", "Message envoyé avec succès. Merci, je vous réponds rapidement.");
          setLiveText("Message envoyé avec succès. Merci, je vous réponds rapidement.");
        } else if (queryStatus === "error") {
          renderStatusMessage("error", "Un problème est survenu pendant l'envoi. Merci de réessayer ou d'appeler directement.");
        }

        if (!(submitButton instanceof HTMLButtonElement)) return;
        if (startedAtInput instanceof HTMLInputElement) {
          startedAtInput.value = new Date().toISOString();
        }
        if (!endpoint) return;

        form.addEventListener("submit", async (event) => {
          event.preventDefault();
          clearStatusMessage();

          if (!form.checkValidity()) {
            form.reportValidity();
            setLiveText("Merci de corriger les champs en erreur.");
            return;
          }

          const tokenInput = form.querySelector("input[name='cf-turnstile-response']");
          if (!(tokenInput instanceof HTMLInputElement) || !tokenInput.value.trim()) {
            setLiveText("Merci de valider l'étape de sécurité anti-spam.");
            return;
          }

          submitButton.disabled = true;
          submitButton.setAttribute("aria-busy", "true");
          setLiveText("Envoi en cours...");

          try {
            const formData = new FormData(form);
            const payload = Object.fromEntries(formData.entries());
            const response = await fetch(endpoint, {
              method: "POST",
              body: JSON.stringify(payload),
              headers: {
                Accept: "application/json",
                "Content-Type": "application/json",
              },
            });

            if (!response.ok) {
              let serverMessage = "Envoi refusé";
              try {
                const data = await response.json();
                if (data && typeof data.error === "string" && data.error.trim()) {
                  serverMessage = data.error;
                }
              } catch {}
              throw new Error(serverMessage);
            }

            form.reset();
            window.turnstile?.reset();
            renderStatusMessage("success", "Message envoyé avec succès. Merci, je vous réponds rapidement.");
            setLiveText("Message envoyé avec succès. Merci, je vous réponds rapidement.");
          } catch (error) {
            const message =
              error instanceof Error && error.message
                ? `L'envoi a échoué: ${error.message}.`
                : "L'envoi a échoué. Merci de réessayer dans quelques instants.";
            setLiveText(message);
          } finally {
            submitButton.disabled = false;
            submitButton.removeAttribute("aria-busy");
          }
        });
      });
    </script>
  </Fragment>
</BaseLayout>

<style>
  .contact-form-section {
    margin-top: 2rem;
    width: 100%;
    max-width: 100%;
    padding: 1.35rem;
    border: 1px solid var(--line);
    border-radius: 1rem;
    background: color-mix(in oklab, var(--surface) 85%, white);
    box-shadow: var(--shadow-soft);
  }

  .contact-choices {
    margin-top: 1.25rem;
    width: 100%;
    max-width: 100%;
    padding: 1.1rem 1.2rem;
    border: 1px solid color-mix(in oklab, var(--brand) 35%, white);
    border-radius: 1rem;
    background:
      linear-gradient(145deg, color-mix(in oklab, var(--surface) 78%, white), color-mix(in oklab, var(--cream) 62%, white));
    box-shadow: var(--shadow-soft);
  }

  .contact-choices h2 {
    margin-bottom: 0.45rem;
  }

  .contact-choices-intro,
  .contact-choices-help {
    margin: 0.2rem 0 0.7rem;
    color: var(--muted);
  }

  .contact-choices-list {
    margin: 0.2rem 0 1rem;
    padding-left: 1.25rem;
  }

  .contact-booking-btn {
    min-height: 50px;
    padding: 0.72rem clamp(0.85rem, 2.8vw, 1.4rem);
    font-size: clamp(0.86rem, 2.5vw, 1.03rem);
    white-space: nowrap;
    line-height: 1.15;
    letter-spacing: -0.01em;
    box-shadow: 0 16px 26px -16px rgba(31, 59, 47, 0.92);
  }

  .contact-form-intro {
    margin-top: 0;
    color: var(--muted);
  }

  .contact-form {
    display: grid;
    gap: 1rem;
  }

  .form-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .form-field {
    display: grid;
    gap: 0.4rem;
  }

  .form-field label {
    font-weight: 700;
  }

  .form-field input,
  .form-field textarea {
    width: 100%;
    max-width: 100%;
  }

  .form-check {
    display: flex;
    align-items: flex-start;
    gap: 0.65rem;
  }

  .form-check input {
    width: auto;
    margin-top: 0.2rem;
  }

  .form-turnstile {
    margin-top: 0.25rem;
  }

  .form-help {
    margin: 0;
    color: var(--muted);
    font-size: 0.95rem;
  }

  .form-submit {
    width: fit-content;
    border: 0;
    cursor: pointer;
  }

  .form-submit[disabled] {
    cursor: not-allowed;
    opacity: 0.6;
    transform: none;
  }

  .form-alert {
    padding: 0.75rem 0.9rem;
    border-radius: 0.6rem;
    margin-bottom: 1rem;
  }

  .form-alert-prominent {
    margin-top: 1rem;
    margin-bottom: 1.1rem;
    padding: 1rem 1.1rem;
    border-width: 2px;
    font-size: 1.06rem;
    font-weight: 800;
    line-height: 1.45;
    box-shadow: 0 16px 24px -18px rgba(19, 39, 31, 0.85);
  }

  .form-alert-success {
    border: 1px solid color-mix(in oklab, #2d7a4f 50%, white);
    background: color-mix(in oklab, #2d7a4f 12%, white);
    color: #144a31;
  }

  .form-alert-error {
    border: 1px solid color-mix(in oklab, #a92f2f 45%, white);
    background: color-mix(in oklab, #a92f2f 10%, white);
    color: #5f1616;
  }

  .form-live {
    min-height: 1.4em;
    margin: 0;
    font-weight: 700;
  }

  .hp-wrapper {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  @media (max-width: 720px) {
    .contact-form-section {
      padding: 1rem;
    }

    .form-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
