---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPageContent } from "../data/content";
import { getDefaultPageSeo } from "../data/seo";
import { siteConfig } from "../data/site";
import { sanitizeCmsUrl, sanitizeYoutubeVideoId } from "../utils/security";

const slug = "que-se-passe-t-il-en-ce-moment";
const page = await getPageContent(slug);
const defaultSeo = getDefaultPageSeo("/actualites");
const title = page.seoTitle?.trim() || defaultSeo.title;
const description = page.seoDescription?.trim() || defaultSeo.description;
const intro =
  page.actualitesIntro?.trim() ||
  "Retrouvez ici les prochaines dates, ateliers et annonces importantes.";

function getYoutubeEmbedUrl(input?: string): string | null {
  if (!input) return null;
  try {
    const url = new URL(input);
    const host = url.hostname.replace(/^www\./, "");
    let videoId = "";

    if (host === "youtu.be") {
      videoId = url.pathname.split("/").filter(Boolean)[0] ?? "";
    } else if (host === "youtube.com" || host === "m.youtube.com") {
      if (url.pathname === "/watch") {
        videoId = url.searchParams.get("v") ?? "";
      } else if (url.pathname.startsWith("/shorts/") || url.pathname.startsWith("/embed/")) {
        videoId = url.pathname.split("/").filter(Boolean)[1] ?? "";
      }
    }

    if (!videoId) return null;
    const safeVideoId = sanitizeYoutubeVideoId(videoId);
    if (!safeVideoId) return null;
    return `https://www.youtube.com/embed/${safeVideoId}`;
  } catch {
    return null;
  }
}

const newsItems =
  page.actualitesItems
    ?.filter((item) => item.title?.trim() || item.excerpt?.trim())
    .map((item) => {
      const excerpt = item.excerpt?.trim() || "";
      const publishedAt = item.publishedAt
        ? new Intl.DateTimeFormat("fr-FR", { dateStyle: "long" }).format(new Date(item.publishedAt))
        : /27\s+avril/i.test(excerpt)
          ? "27 avril 2025"
          : "";

      return {
        title: item.title?.trim() || "Actualité",
        publishedAt,
        excerpt,
        youtubeEmbedUrl: getYoutubeEmbedUrl(item.youtubeUrl),
        ctaLabel: item.ctaLabel?.trim() || "",
        ctaUrl:
          sanitizeCmsUrl(item.ctaUrl, {
            allowedProtocols: ["https:", "mailto:", "tel:"],
          }) || "",
      };
    }) ?? [];

const fallbackNewsItems = [
  {
    title: "Atelier Cycle Menstruel",
    publishedAt: "27 avril 2025",
    excerpt:
      "Le prochain atelier aura lieu le 27 avril à 10h sur le thème du cycle menstruel. Les places sont limitées pour privilégier la qualité des échanges.",
    youtubeEmbedUrl: "https://www.youtube.com/embed/KV60ZgnwJzk",
    ctaLabel: "Réserver un premier échange",
    ctaUrl: siteConfig.bookingUrl,
  },
];

const displayedNewsItems = newsItems.length > 0 ? newsItems : fallbackNewsItems;
---

<BaseLayout title={title} description={description} keywords={defaultSeo.keywords}>
  <article class="section wp-content actualites-page" aria-labelledby="page-title">
    <h1 id="page-title">{page.title}</h1>
    <p class="actualites-intro actualites-intro-highlight">{intro}</p>

    <div class="actualites-grid" role="list">
      {
        displayedNewsItems.map((item) => (
          <article class="actualite-card" role="listitem">
            <header>
              <h2>{item.title}</h2>
              {item.publishedAt && <p class="actualite-date">{item.publishedAt}</p>}
            </header>
            {item.excerpt && <p class="actualite-text">{item.excerpt}</p>}
            {
              item.youtubeEmbedUrl && (
                <div class="actualite-video">
                  <iframe
                    src={item.youtubeEmbedUrl}
                    title={`Vidéo - ${item.title}`}
                    loading="lazy"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                    referrerpolicy="strict-origin-when-cross-origin"
                    allowfullscreen
                  />
                </div>
              )
            }
            {
              item.ctaLabel && item.ctaUrl && (
                <p class="actualite-cta-wrap">
                  <a class="btn btn-primary btn-booking" href={item.ctaUrl} target="_blank" rel="noopener noreferrer">
                    {item.ctaLabel}
                  </a>
                </p>
              )
            }
          </article>
        ))
      }

      <article class="actualite-card actualite-card-refonte" role="listitem">
        <header>
          <h2>Refonte du site: version grand public</h2>
          <p class="actualite-date">Avril 2025</p>
        </header>
        <p class="actualite-text">
          Le site évolue pour devenir plus clair, plus lisible et plus simple à utiliser au quotidien. Cette version
          grand public met l'accent sur une navigation fluide, des informations essentielles accessibles rapidement et
          une meilleure expérience sur mobile comme sur ordinateur.
        </p>
      </article>
    </div>
  </article>
</BaseLayout>
