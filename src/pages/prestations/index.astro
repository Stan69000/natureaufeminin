---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageContent } from "../../data/content";
import { getDefaultPageSeo } from "../../data/seo";
import { serviceCards } from "../../data/site";
import { sanitizeCmsUrl } from "../../utils/security";

const slug = "prestations";
const page = await getPageContent(slug);
const defaultSeo = getDefaultPageSeo("/prestations");
const title = page.seoTitle?.trim() || defaultSeo.title;
const description = page.seoDescription?.trim() || defaultSeo.description;
const menuTitle = page.prestationsMenuTitle?.trim() || "Nos accompagnements";
const menuIntro =
  page.prestationsIntro?.trim() ||
  "Afin de vous accompagner au mieux dans vos changements de vie, voici les différentes prestations que je propose :";
const menuItems =
  page.prestationsMenu
    ?.filter((item) => item.label?.trim() && item.href?.trim())
    .map((item) => ({
      label: item.label ?? "",
      href:
        sanitizeCmsUrl(item.href, {
          allowRelative: true,
          allowedProtocols: ["https:"],
        }) || "",
      description: item.description ?? "",
    }))
    .filter((item) => item.href) ??
  [];
const displayedMenuItems =
  menuItems.length > 0
    ? menuItems
    : serviceCards.map((item) => ({
        label: item.title,
        href: item.href,
        description: item.description,
      }));
---

<BaseLayout title={title} description={description} keywords={defaultSeo.keywords}>
  <article class="section wp-content prestations-content" aria-labelledby="page-title">
    <h1 id="page-title">{page.title}</h1>
    <nav class="prestations-submenu" aria-label="Sous-menu prestations">
      <p class="prestations-submenu-title">{menuTitle}</p>
      {menuIntro && <p class="prestations-submenu-intro">{menuIntro}</p>}
      <p class="prestations-submenu-intro">
        Vous pouvez être accompagnée au cabinet, à domicile selon le secteur ou en visio.
        <a href="/zones-desservies"> Voir les zones desservies</a>.
      </p>
      <p class="prestations-submenu-intro">
        Recherche “Ouest lyonnais” : <a href="/ouest-lyonnais">voir la page dédiée</a>.
      </p>
      <ul>
        {
          displayedMenuItems.map((item) => (
            <li>
              <a href={item.href}>
                <strong>{item.label}</strong>
                {item.description && <small>{item.description}</small>}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </article>
</BaseLayout>
