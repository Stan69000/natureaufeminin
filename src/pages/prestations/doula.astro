---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PrestationSupportBlocks from "../../components/PrestationSupportBlocks.astro";
import { getPageContent } from "../../data/content";
import { getDefaultPageDescription } from "../../data/seo";
import { getPrestationSeo } from "../../data/prestations-seo";

const slug = "doula-un-bebe-pour-bientot";
const path = "/prestations/doula";
const page = await getPageContent(slug);
const title = page.seoTitle?.trim() || `${page.title} | Natur' Au Feminin`;
const description = page.seoDescription?.trim() || getDefaultPageDescription(path);
const html = page.html;
const prestationSeo = getPrestationSeo(path);
---

<BaseLayout title={title} description={description} structuredData={prestationSeo.structuredData}>
  <article class="section wp-content" aria-labelledby="page-title">
    <h1 id="page-title">{page.title}</h1>
    <div set:html={html}></div>
    <PrestationSupportBlocks faqItems={prestationSeo.faqItems} internalLinks={prestationSeo.internalLinks} />
  </article>
</BaseLayout>
