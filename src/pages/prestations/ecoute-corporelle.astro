---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PrestationSupportBlocks from "../../components/PrestationSupportBlocks.astro";
import { getPageContent } from "../../data/content";
import { getDefaultPageSeo } from "../../data/seo";
import { getPrestationSeo } from "../../data/prestations-seo";
import { siteConfig } from "../../data/site";

const slug = "lecoute-corporelle-par-la-voie-des-sens";
const path = "/prestations/ecoute-corporelle";
const page = await getPageContent(slug);
const defaultSeo = getDefaultPageSeo(path);
const title = page.seoTitle?.trim() || defaultSeo.title;
const description = page.seoDescription?.trim() || defaultSeo.description;
const html = page.html;
const prestationSeo = getPrestationSeo(path);

function toParagraphs(input: string): string[] {
  const decode = (value: string) =>
    value
      .replace(/&amp;#x27;|&#x27;|&#39;|&rsquo;/gi, "'")
      .replace(/&amp;|&#038;/gi, "&")
      .replace(/&nbsp;/gi, " ")
      .replace(/&ldquo;|&rdquo;/gi, '"')
      .replace(/&ndash;|&mdash;/gi, "-");

  const noStyle = input
    .replace(/<style[\s\S]*?<\/style>/gi, "")
    .replace(/<script[\s\S]*?<\/script>/gi, "")
    .replace(/<a[^>]*class="btn-liberlo"[\s\S]*?<\/a>/gi, "")
    .replace(/<br\s*\/?>/gi, "\n")
    .replace(/<\/(p|h1|h2|h3|h4|li|ul|ol|blockquote|div)>/gi, "\n\n")
    .replace(/<[^>]+>/g, "")
    .replace(/\r/g, "")
    .replace(/\n{3,}/g, "\n\n")
    .trim();

  return decode(noStyle)
    .split(/\n{2,}/)
    .map((line) => line.trim())
    .filter((line) => !/^rdv sur liberlo\.com$/i.test(line))
    .filter(Boolean);
}

const paragraphs = toParagraphs(html);
const lead = paragraphs[0] ?? "";
const rest = paragraphs.slice(1);
---

<BaseLayout
  title={title}
  description={description}
  keywords={defaultSeo.keywords}
  structuredData={prestationSeo.structuredData}
>
  <article class="section wp-content ecoute-page" aria-labelledby="page-title">
    <h1 id="page-title">{page.title}</h1>

    {lead && <p class="ecoute-lead">{lead}</p>}

    <div class="ecoute-body">
      {rest.map((paragraph) => <p>{paragraph}</p>)}
    </div>

    <PrestationSupportBlocks faqItems={prestationSeo.faqItems} internalLinks={prestationSeo.internalLinks} />

    <p class="ecoute-cta-wrap">
      <a
        class="btn btn-primary btn-booking ecoute-cta"
        href={siteConfig.bookingUrl}
        target="_blank"
        rel="noopener noreferrer"
      >
        Réserver un premier échange
      </a>
    </p>
  </article>
</BaseLayout>
