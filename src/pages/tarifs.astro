---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPageContent } from "../data/content";
import { getDefaultPageDescription } from "../data/seo";
import { siteConfig } from "../data/site";
import { sanitizeCmsUrl } from "../utils/security";

const slug = "tarifs";
const page = await getPageContent(slug);
const title = page.seoTitle?.trim() || `${page.title} | Natur' Au Feminin`;
const description = page.seoDescription?.trim() || getDefaultPageDescription("/tarifs");
const intro = page.pricingIntro?.trim() || "";
const ctaText = page.pricingCtaText?.trim() || "Un doute sur la formule adaptée ?";
const ctaLabel = page.pricingCtaLabel?.trim() || "Réserver un premier échange";
const ctaUrl =
  sanitizeCmsUrl(page.pricingCtaUrl, {
    allowedProtocols: ["https:", "mailto:", "tel:"],
  }) || siteConfig.bookingUrl;

const fallbackSections = [
  {
    title: "Symptothermie",
    items: [
      { label: "Bilan 1ère rencontre", price: "90 €" },
      { label: "Entraînement Sympto (4 rdv + @ + tél. sur 1 an)", price: "300 €" },
      { label: "Séance de suivi après 1 an", price: "60 €" },
      { label: "Le cycle dans toute sa splendeur (5 séances)", price: "250 €" },
    ],
  },
  {
    title: "Accompagnement Doula",
    items: [
      { label: "Notre 1ère rencontre", price: "90 €" },
      { label: "Forfait préconception (4 rendez-vous)", price: "320 €" },
      { label: "Forfait grossesse (10 rdv)", price: "750 €" },
      { label: "Forfait post-partum (6 rdv à domicile)", price: "540 €" },
    ],
  },
  {
    title: "Massage Ayurvédique",
    items: [
      { label: "Massage Ayurvédique", price: "120 €" },
      { label: "Pack 3 massages Ayurvédiques", price: "330 €" },
      { label: "Pack 5 massages", price: "450 €" },
    ],
  },
  {
    title: "Massage Bébé",
    items: [
      { label: "Notre 1ère rencontre", price: "90 €" },
      { label: "Forfait préconception (4 rendez-vous)", price: "320 €" },
      { label: "Forfait grossesse (10 rdv)", price: "750 €" },
      { label: "Forfait post-partum (6 rdv à domicile)", price: "540 €" },
    ],
  },
];

const pricingSections =
  page.pricingSections
    ?.filter(
      (section) =>
        section.title?.trim() &&
        section.items?.some((item) => item.label?.trim() && item.price?.trim()),
    )
    .map((section) => ({
      title: section.title ?? "",
      items:
        section.items
          ?.filter((item) => item.label?.trim() && item.price?.trim())
          .map((item) => ({ label: item.label ?? "", price: item.price ?? "" })) ?? [],
    })) ?? [];
const displayedSections = pricingSections.length > 0 ? pricingSections : fallbackSections;
const normalizeSectionTitle = (value) =>
  (value ?? "")
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .trim();

const desiredSectionOrder = [
  "naturopathie",
  "symptothermie",
  "accompagnement doula",
  "massage ayurvedique",
  "massage bebe",
];

const sectionByNormalizedTitle = new Map(
  displayedSections.map((section) => [normalizeSectionTitle(section.title), section]),
);

const orderedSections = [
  ...desiredSectionOrder
    .map((title) => sectionByNormalizedTitle.get(title))
    .filter(Boolean),
  ...displayedSections.filter(
    (section) => !desiredSectionOrder.includes(normalizeSectionTitle(section.title)),
  ),
];

const reorderDoulaItems = (items = []) => {
  const firstMeetingIndex = items.findIndex(
    (item) => (item?.label ?? "").trim().toLowerCase() === "notre 1ère rencontre",
  );
  const followupIndex = items.findIndex(
    (item) => (item?.label ?? "").trim().toLowerCase() === "séance de suivi doula",
  );

  if (firstMeetingIndex === -1 || followupIndex === -1) return items;
  if (followupIndex === firstMeetingIndex + 1) return items;

  const nextItems = [...items];
  const [followupItem] = nextItems.splice(followupIndex, 1);
  const insertIndex = firstMeetingIndex < followupIndex ? firstMeetingIndex + 1 : firstMeetingIndex + 1;
  nextItems.splice(insertIndex, 0, followupItem);
  return nextItems;
};

const normalizedDoulaTitle = "accompagnement doula";
const sectionsWithOrderedDoula = orderedSections.map((section) => {
  if (normalizeSectionTitle(section.title) !== normalizedDoulaTitle) return section;
  return {
    ...section,
    items: reorderDoulaItems(section.items ?? []),
  };
});

const sideSection =
  sectionsWithOrderedDoula.find((section) => normalizeSectionTitle(section.title) === "massage bebe") ?? null;
const mainSections = sideSection
  ? sectionsWithOrderedDoula.filter((section) => section !== sideSection)
  : sectionsWithOrderedDoula;
const formatPrice = (value) => {
  const raw = (value ?? "").trim();
  if (!raw) return "";
  return /€|euro/i.test(raw) ? raw : `${raw} €`;
};
---

<BaseLayout title={title} description={description}>
  <article class="section wp-content tarifs-content" aria-labelledby="page-title">
    <h1 id="page-title">{page.title}</h1>
    {intro && <p class="tarifs-intro">{intro}</p>}

    <div class="tarifs-grid" role="list">
      {
        mainSections.map((section) => (
          <section class="tarif-card" role="listitem" aria-label={section.title}>
            <h2>{section.title}</h2>
            <ul>
              {section.items?.map((item) => <li><span>{item.label}</span><strong>{formatPrice(item.price)}</strong></li>)}
            </ul>
          </section>
        ))
      }
    </div>

    {
      sideSection && (
        <section class="tarifs-side-row" aria-label="Bloc Massage Bébé et appel à l'action">
          <section class="tarif-card" aria-label={sideSection.title}>
            <h2>{sideSection.title}</h2>
            <ul>
              {sideSection.items?.map((item) => <li><span>{item.label}</span><strong>{formatPrice(item.price)}</strong></li>)}
            </ul>
          </section>
          <aside class="tarifs-cta-panel">
            <p class="tarifs-cta-text">{ctaText}</p>
            <a
              class="btn btn-primary btn-booking tarifs-cta-button"
              href={ctaUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              {ctaLabel}
            </a>
          </aside>
        </section>
      )
    }
  </article>
</BaseLayout>
